<?xml version="1.0"?>
<!--
/**
 * Storefront route: /shamcash/payment/* (instructions, check).
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="shamcash" frontName="shamcash">
            <module name="ShamCash_Payment"/>
        </route>
    </router>
</config>
