<?xml version="1.0"?>
<!--
/**
 * Admin configuration UI: Stores > Configuration > Sales > Payment Methods > Sham Cash.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="shamcash" translate="label comment" type="text" sortOrder="40"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Sham Cash (شام كاش)</label>
                <comment><![CDATA[Accept Sham Cash e-wallet payments by reconciliation. The Sham Cash API is read-only, so customers transfer to your wallet and orders are confirmed automatically once the matching transfer is read from <a href="https://api.shamcash-api.com/v1" target="_blank">/transactions</a>.]]></comment>
                <field id="active" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>payment/shamcash/active</config_path>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                    <config_path>payment/shamcash/title</config_path>
                </field>

                <field id="api_base_url" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Base URL</label>
                    <comment>Default: https://api.shamcash-api.com/v1</comment>
                    <config_path>payment/shamcash/api_base_url</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="api_token" translate="label comment" type="obscure" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Token</label>
                    <comment>Bearer token issued from the Sham Cash API dashboard. Stored encrypted.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>payment/shamcash/api_token</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="account_id" translate="label comment" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Account ID</label>
                    <comment>The linked Sham Cash account that receives transfers (from /accounts).</comment>
                    <config_path>payment/shamcash/account_id</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="refresh_account" translate="label" sortOrder="55"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Account info</label>
                    <frontend_model>ShamCash\Payment\Block\Adminhtml\System\Config\RefreshButton</frontend_model>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="account_address" translate="label comment" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Wallet Address</label>
                    <comment>Shown to customers. Auto-filled by "Refresh account info".</comment>
                    <config_path>payment/shamcash/account_address</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="account_qr_payload" translate="label comment" type="textarea" sortOrder="70"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>QR Payload</label>
                    <comment>Encoded as a QR at checkout. Auto-filled by "Refresh account info".</comment>
                    <config_path>payment/shamcash/account_qr_payload</config_path>
                    <depends><field id="active">1</field></depends>
                </field>

                <field id="allowed_currencies" translate="label comment" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Allowed Currencies</label>
                    <comment>Comma-separated ISO codes. Default: SYP,USD,TRY</comment>
                    <config_path>payment/shamcash/allowed_currencies</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="coin_map" translate="label comment" type="textarea" sortOrder="90"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Currency to coin_id Map</label>
                    <comment><![CDATA[Optional /transactions filter. One per line or comma-separated, e.g. <code>SYP:1, USD:2, TRY:3</code>.]]></comment>
                    <config_path>payment/shamcash/coin_map</config_path>
                    <depends><field id="active">1</field></depends>
                </field>

                <field id="matching_mode" translate="label" type="select" sortOrder="100"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Matching Mode</label>
                    <source_model>ShamCash\Payment\Model\Config\Source\MatchingMode</source_model>
                    <config_path>payment/shamcash/matching_mode</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="amount_tolerance" translate="label comment" type="text" sortOrder="110"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Amount Tolerance</label>
                    <comment>Absolute tolerance when verifying the transferred amount. Default: 0</comment>
                    <config_path>payment/shamcash/amount_tolerance</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="time_window_grace" translate="label comment" type="text" sortOrder="120"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Time Window Grace (minutes)</label>
                    <comment>Search transactions from this many minutes before the order was placed.</comment>
                    <config_path>payment/shamcash/time_window_grace</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="order_max_age" translate="label comment" type="text" sortOrder="130"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Order Max Age (minutes)</label>
                    <comment>Stop auto-polling a pending order older than this. Default: 1440</comment>
                    <config_path>payment/shamcash/order_max_age</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="customer_check_rate_limit" translate="label comment" type="text" sortOrder="140"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Customer Check Rate Limit (seconds)</label>
                    <comment>Minimum seconds between "I've paid" checks for one order.</comment>
                    <config_path>payment/shamcash/customer_check_rate_limit</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="cron_expr" translate="label comment" type="text" sortOrder="150"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Reconciliation Cron Schedule</label>
                    <comment>Crontab expression for the background poller. Default: */5 * * * *</comment>
                    <config_path>payment/shamcash/cron_expr</config_path>
                    <depends><field id="active">1</field></depends>
                </field>

                <field id="order_status" translate="label" type="select" sortOrder="160"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>New Order Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                    <config_path>payment/shamcash/order_status</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="instructions" translate="label comment" type="textarea" sortOrder="170"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Checkout Instructions</label>
                    <comment><![CDATA[Placeholders: <code>{amount}</code>, <code>{currency}</code>, <code>{address}</code>, <code>{reference}</code>.]]></comment>
                    <config_path>payment/shamcash/instructions</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="debug" translate="label" type="select" sortOrder="180"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Debug Logging</label>
                    <comment>Logs API calls to var/log/shamcash.log.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>payment/shamcash/debug</config_path>
                    <depends><field id="active">1</field></depends>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="190"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sort Order</label>
                    <config_path>payment/shamcash/sort_order</config_path>
                </field>
            </group>
        </section>
    </system>
</config>
